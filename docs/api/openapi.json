{
  "openapi": "3.0.3",
  "info": {
    "title": "IT项目管理系统 API",
    "description": "IT Project Management System - RESTful API Documentation",
    "version": "1.0.0"
  },
  "servers": [
    { "url": "http://localhost:8080", "description": "开发环境" }
  ],
  "components": {
    "securitySchemes": {
      "Bearer": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" }
    },
    "schemas": {
      "Result": {
        "type": "object",
        "properties": {
          "code": { "type": "integer" },
          "message": { "type": "string" },
          "data": { "type": "object" },
          "timestamp": { "type": "integer" }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["username", "password"],
        "properties": {
          "username": { "type": "string" },
          "password": { "type": "string" }
        }
      },
      "TokenResponse": {
        "type": "object",
        "properties": {
          "accessToken": { "type": "string" },
          "refreshToken": { "type": "string" },
          "tokenType": { "type": "string" },
          "expiresIn": { "type": "integer" },
          "userInfo": { "$ref": "#/components/schemas/UserInfoVO" }
        }
      },
      "UserInfoVO": {
        "type": "object",
        "properties": {
          "userId": { "type": "integer" },
          "username": { "type": "string" },
          "realName": { "type": "string" },
          "role": { "type": "string" },
          "orgId": { "type": "integer" }
        }
      },
      "ProjectCreateRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "projectCode": { "type": "string" },
          "description": { "type": "string" },
          "type": { "type": "string", "enum": ["software_dev","system_integration","ops","other"] },
          "priority": { "type": "string", "enum": ["critical","high","medium","low"] },
          "promotionEnabled": { "type": "integer" },
          "startDate": { "type": "string", "format": "date" },
          "endDate": { "type": "string", "format": "date" },
          "orgId": { "type": "integer" },
          "remark": { "type": "string" }
        }
      },
      "ProjectUpdateRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "type": { "type": "string" },
          "status": { "type": "string", "enum": ["planning","in_progress","on_hold","closed"] },
          "priority": { "type": "string" },
          "startDate": { "type": "string", "format": "date" },
          "endDate": { "type": "string", "format": "date" },
          "remark": { "type": "string" }
        }
      },
      "ProjectVO": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "projectCode": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "type": { "type": "string" },
          "status": { "type": "string" },
          "priority": { "type": "string" },
          "promotionEnabled": { "type": "integer" },
          "startDate": { "type": "string", "format": "date" },
          "endDate": { "type": "string", "format": "date" },
          "projectManagerId": { "type": "integer" },
          "orgId": { "type": "integer" },
          "remark": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "memberCount": { "type": "integer" }
        }
      },
      "RequirementCreateRequest": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string" },
          "acceptanceCriteria": { "type": "string" },
          "priority": { "type": "string", "enum": ["critical","high","medium","low"] },
          "source": { "type": "string", "enum": ["business","tech","regulatory"] },
          "category": { "type": "string", "enum": ["general","differential"] },
          "assignedTo": { "type": "integer" },
          "milestoneId": { "type": "integer" },
          "estimatedHours": { "type": "number" }
        }
      },
      "RequirementVO": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "projectId": { "type": "integer" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "acceptanceCriteria": { "type": "string" },
          "priority": { "type": "string" },
          "status": { "type": "string" },
          "source": { "type": "string" },
          "category": { "type": "string" },
          "assignedTo": { "type": "integer" },
          "milestoneId": { "type": "integer" },
          "estimatedHours": { "type": "number" },
          "actualHours": { "type": "number" },
          "remark": { "type": "string" },
          "createdBy": { "type": "integer" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "StatusUpdateRequest": {
        "type": "object",
        "required": ["targetStatus"],
        "properties": {
          "targetStatus": { "type": "string", "enum": ["reviewing","approved","scheduled","done","rejected","draft"] },
          "remark": { "type": "string" }
        }
      },
      "TaskCreateRequest": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string" },
          "parentTaskId": { "type": "integer" },
          "requirementId": { "type": "integer" },
          "type": { "type": "string", "enum": ["dev","test","deploy","training","design","review","other"] },
          "priority": { "type": "string", "enum": ["critical","high","medium","low"] },
          "assignedTo": { "type": "integer" },
          "plannedStart": { "type": "string", "format": "date" },
          "plannedEnd": { "type": "string", "format": "date" }
        }
      },
      "TaskVO": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "projectId": { "type": "integer" },
          "parentTaskId": { "type": "integer" },
          "requirementId": { "type": "integer" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "type": { "type": "string" },
          "status": { "type": "string" },
          "priority": { "type": "string" },
          "assignedTo": { "type": "integer" },
          "plannedStart": { "type": "string", "format": "date" },
          "plannedEnd": { "type": "string", "format": "date" },
          "actualStart": { "type": "string", "format": "date" },
          "actualEnd": { "type": "string", "format": "date" },
          "completionRate": { "type": "number" },
          "estimatedHours": { "type": "number" },
          "actualHours": { "type": "number" },
          "wbsCode": { "type": "string" },
          "sortOrder": { "type": "integer" },
          "remark": { "type": "string" },
          "children": { "type": "array", "items": { "$ref": "#/components/schemas/TaskVO" } },
          "dependsOnTaskIds": { "type": "array", "items": { "type": "integer" } },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "ProgressUpdateRequest": {
        "type": "object",
        "required": ["completionRate"],
        "properties": {
          "completionRate": { "type": "number", "minimum": 0, "maximum": 100 },
          "remark": { "type": "string" }
        }
      },
      "DependencyRequest": {
        "type": "object",
        "required": ["dependsOnTaskId"],
        "properties": {
          "dependsOnTaskId": { "type": "integer" },
          "dependencyType": { "type": "string", "enum": ["FS","FF","SS","SF"] }
        }
      },
      "MilestoneCreateRequest": {
        "type": "object",
        "required": ["name", "plannedDate"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "plannedDate": { "type": "string", "format": "date" },
          "sortOrder": { "type": "integer" }
        }
      },
      "MilestoneUpdateRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "plannedDate": { "type": "string", "format": "date" },
          "actualDate": { "type": "string", "format": "date" },
          "status": { "type": "string", "enum": ["pending","in_progress","at_risk","completed","delayed"] },
          "sortOrder": { "type": "integer" }
        }
      },
      "MilestoneVO": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "projectId": { "type": "integer" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "plannedDate": { "type": "string", "format": "date" },
          "actualDate": { "type": "string", "format": "date" },
          "status": { "type": "string" },
          "sortOrder": { "type": "integer" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      }
    }
  },
  "security": [{ "Bearer": [] }],
  "paths": {
    "/api/auth/login": {
      "post": {
        "tags": ["认证管理"],
        "summary": "用户登录",
        "security": [],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LoginRequest" } } } },
        "responses": { "200": { "description": "登录成功", "content": { "application/json": { "schema": { "allOf": [{ "$ref": "#/components/schemas/Result" }, { "properties": { "data": { "$ref": "#/components/schemas/TokenResponse" } } }] } } } } }
      }
    },
    "/api/auth/refresh": {
      "post": {
        "tags": ["认证管理"],
        "summary": "刷新Token",
        "security": [],
        "parameters": [{ "name": "refreshToken", "in": "query", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "刷新成功" } }
      }
    },
    "/api/auth/logout": {
      "post": { "tags": ["认证管理"], "summary": "用户登出", "responses": { "200": { "description": "登出成功" } } }
    },
    "/api/auth/me": {
      "get": { "tags": ["认证管理"], "summary": "获取当前用户信息", "responses": { "200": { "description": "成功" } } }
    },
    "/api/projects": {
      "post": {
        "tags": ["项目管理"],
        "summary": "创建项目",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProjectCreateRequest" } } } },
        "responses": { "200": { "description": "创建成功", "content": { "application/json": { "schema": { "allOf": [{ "$ref": "#/components/schemas/Result" }, { "properties": { "data": { "$ref": "#/components/schemas/ProjectVO" } } }] } } } } }
      },
      "get": {
        "tags": ["项目管理"],
        "summary": "项目列表（分页）",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "size", "in": "query", "schema": { "type": "integer", "default": 20 } },
          { "name": "keyword", "in": "query", "schema": { "type": "string" } },
          { "name": "status", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "成功" } }
      }
    },
    "/api/projects/{projectId}": {
      "get": { "tags": ["项目管理"], "summary": "项目详情", "parameters": [{ "name": "projectId", "in": "path", "required": true, "schema": { "type": "integer" } }], "responses": { "200": { "description": "成功" } } },
      "put": { "tags": ["项目管理"], "summary": "更新项目", "parameters": [{ "name": "projectId", "in": "path", "required": true, "schema": { "type": "integer" } }], "requestBody": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProjectUpdateRequest" } } } }, "responses": { "200": { "description": "更新成功" } } },
      "delete": { "tags": ["项目管理"], "summary": "删除项目", "parameters": [{ "name": "projectId", "in": "path", "required": true, "schema": { "type": "integer" } }], "responses": { "200": { "description": "删除成功" } } }
    },
    "/api/projects/{projectId}/members": {
      "post": { "tags": ["项目管理"], "summary": "添加项目成员", "parameters": [{ "name": "projectId", "in": "path", "required": true, "schema": { "type": "integer" } }, { "name": "userId", "in": "query", "required": true, "schema": { "type": "integer" } }, { "name": "role", "in": "query", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "添加成功" } } },
      "get": { "tags": ["项目管理"], "summary": "项目成员列表", "parameters": [{ "name": "projectId", "in": "path", "required": true, "schema": { "type": "integer" } }], "responses": { "200": { "description": "成功" } } }
    },
    "/api/projects/{projectId}/members/{userId}": {
      "delete": { "tags": ["项目管理"], "summary": "移除项目成员", "parameters": [{ "name": "projectId", "in": "path", "required": true, "schema": { "type": "integer" } }, { "name": "userId", "in": "path", "required": true, "schema": { "type": "integer" } }], "responses": { "200": { "description": "移除成功" } } }
    },
    "/api/projects/{projectId}/requirements": {
      "post": { "tags": ["需求管理"], "summary": "创建需求", "parameters": [{ "name": "projectId", "in": "path", "required": true, "schema": { "type": "integer" } }], "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RequirementCreateRequest" } } } }, "responses": { "200": { "description": "创建成功" } } },
      "get": { "tags": ["需求管理"], "summary": "需求列表（分页）", "parameters": [{ "name": "projectId", "in": "path", "required": true, "schema": { "type": "integer" } }, { "name": "page", "in": "query", "schema": { "type": "integer" } }, { "name": "size", "in": "query", "schema": { "type": "integer" } }, { "name": "keyword", "in": "query", "schema": { "type": "string" } }, { "name": "status", "in": "query", "schema": { "type": "string" } }], "responses": { "200": { "description": "成功" } } }
    },
    "/api/requirements/{requirementId}": {
      "get": { "tags": ["需求管理"], "summary": "需求详情", "parameters": [{ "name": "requirementId", "in": "path", "required": true, "schema": { "type": "integer" } }], "responses": { "200": { "description": "成功" } } },
      "put": { "tags": ["需求管理"], "summary": "更新需求", "parameters": [{ "name": "requirementId", "in": "path", "required": true, "schema": { "type": "integer" } }], "requestBody": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RequirementCreateRequest" } } } }, "responses": { "200": { "description": "更新成功" } } },
      "delete": { "tags": ["需求管理"], "summary": "删除需求", "parameters": [{ "name": "requirementId", "in": "path", "required": true, "schema": { "type": "integer" } }], "responses": { "200": { "description": "删除成功" } } }
    },
    "/api/requirements/{requirementId}/status": {
      "put": { "tags": ["需求管理"], "summary": "需求状态流转", "parameters": [{ "name": "requirementId", "in": "path", "required": true, "schema": { "type": "integer" } }], "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/StatusUpdateRequest" } } } }, "responses": { "200": { "description": "状态更新成功" } } }
    },
    "/api/projects/{projectId}/requirements/pool": {
      "get": { "tags": ["需求管理"], "summary": "需求池（未排期需求）", "parameters": [{ "name": "projectId", "in": "path", "required": true, "schema": { "type": "integer" } }], "responses": { "200": { "description": "成功" } } }
    },
    "/api/requirements/{requirementId}/assign": {
      "post": { "tags": ["需求管理"], "summary": "指派需求负责人", "parameters": [{ "name": "requirementId", "in": "path", "required": true, "schema": { "type": "integer" } }, { "name": "userId", "in": "query", "required": true, "schema": { "type": "integer" } }], "responses": { "200": { "description": "指派成功" } } }
    },
    "/api/projects/{projectId}/tasks": {
      "post": { "tags": ["任务管理"], "summary": "创建任务", "parameters": [{ "name": "projectId", "in": "path", "required": true, "schema": { "type": "integer" } }], "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TaskCreateRequest" } } } }, "responses": { "200": { "description": "创建成功" } } },
      "get": { "tags": ["任务管理"], "summary": "任务列表（分页）", "parameters": [{ "name": "projectId", "in": "path", "required": true, "schema": { "type": "integer" } }, { "name": "page", "in": "query", "schema": { "type": "integer" } }, { "name": "size", "in": "query", "schema": { "type": "integer" } }, { "name": "keyword", "in": "query", "schema": { "type": "string" } }, { "name": "status", "in": "query", "schema": { "type": "string" } }], "responses": { "200": { "description": "成功" } } }
    },
    "/api/tasks/{taskId}": {
      "get": { "tags": ["任务管理"], "summary": "任务详情", "parameters": [{ "name": "taskId", "in": "path", "required": true, "schema": { "type": "integer" } }], "responses": { "200": { "description": "成功" } } },
      "put": { "tags": ["任务管理"], "summary": "更新任务", "parameters": [{ "name": "taskId", "in": "path", "required": true, "schema": { "type": "integer" } }], "requestBody": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TaskCreateRequest" } } } }, "responses": { "200": { "description": "更新成功" } } },
      "delete": { "tags": ["任务管理"], "summary": "删除任务", "parameters": [{ "name": "taskId", "in": "path", "required": true, "schema": { "type": "integer" } }], "responses": { "200": { "description": "删除成功" } } }
    },
    "/api/tasks/{taskId}/progress": {
      "put": { "tags": ["任务管理"], "summary": "更新任务进度", "parameters": [{ "name": "taskId", "in": "path", "required": true, "schema": { "type": "integer" } }], "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProgressUpdateRequest" } } } }, "responses": { "200": { "description": "更新成功" } } }
    },
    "/api/tasks/{parentTaskId}/subtasks": {
      "post": { "tags": ["任务管理"], "summary": "创建子任务（WBS分解）", "parameters": [{ "name": "parentTaskId", "in": "path", "required": true, "schema": { "type": "integer" } }], "requestBody": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TaskCreateRequest" } } } }, "responses": { "200": { "description": "创建成功" } } },
      "get": { "tags": ["任务管理"], "summary": "获取子任务列表", "parameters": [{ "name": "parentTaskId", "in": "path", "required": true, "schema": { "type": "integer" } }], "responses": { "200": { "description": "成功" } } }
    },
    "/api/projects/{projectId}/tasks/wbs": {
      "get": { "tags": ["任务管理"], "summary": "获取WBS完整树结构", "parameters": [{ "name": "projectId", "in": "path", "required": true, "schema": { "type": "integer" } }], "responses": { "200": { "description": "成功" } } }
    },
    "/api/tasks/{taskId}/dependencies": {
      "post": { "tags": ["任务管理"], "summary": "添加任务依赖", "parameters": [{ "name": "taskId", "in": "path", "required": true, "schema": { "type": "integer" } }], "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DependencyRequest" } } } }, "responses": { "200": { "description": "添加成功" } } }
    },
    "/api/projects/{projectId}/milestones": {
      "post": { "tags": ["里程碑管理"], "summary": "创建里程碑", "parameters": [{ "name": "projectId", "in": "path", "required": true, "schema": { "type": "integer" } }], "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MilestoneCreateRequest" } } } }, "responses": { "200": { "description": "创建成功" } } },
      "get": { "tags": ["里程碑管理"], "summary": "里程碑列表（分页）", "parameters": [{ "name": "projectId", "in": "path", "required": true, "schema": { "type": "integer" } }, { "name": "page", "in": "query", "schema": { "type": "integer" } }, { "name": "size", "in": "query", "schema": { "type": "integer" } }, { "name": "status", "in": "query", "schema": { "type": "string" } }], "responses": { "200": { "description": "成功" } } }
    },
    "/api/milestones/{milestoneId}": {
      "get": { "tags": ["里程碑管理"], "summary": "里程碑详情", "parameters": [{ "name": "milestoneId", "in": "path", "required": true, "schema": { "type": "integer" } }], "responses": { "200": { "description": "成功" } } },
      "put": { "tags": ["里程碑管理"], "summary": "更新里程碑", "parameters": [{ "name": "milestoneId", "in": "path", "required": true, "schema": { "type": "integer" } }], "requestBody": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MilestoneUpdateRequest" } } } }, "responses": { "200": { "description": "更新成功" } } },
      "delete": { "tags": ["里程碑管理"], "summary": "删除里程碑", "parameters": [{ "name": "milestoneId", "in": "path", "required": true, "schema": { "type": "integer" } }], "responses": { "200": { "description": "删除成功" } } }
    }
  }
}
